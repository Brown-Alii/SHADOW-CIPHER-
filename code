def decode_binary(binary_input: str) -> str:
    """Convert space-separated 8-bit binary groups to readable text."""
    groups = binary_input.strip().split()
    result = ""
 
    for i, group in enumerate(groups):
        if not all(c in '01' for c in group):
            raise ValueError(f"Invalid character in group {i+1}: '{group}' (only 0s and 1s allowed)")
        if len(group) != 8:
            raise ValueError(f"Group {i+1} has {len(group)} bits вҖ” each group must be exactly 8 bits")
 
        code = int(group, 2)
        result += chr(code)
 
    return result
 
 
def encode_to_binary(text: str) -> str:
    """Convert plain text to space-separated 8-bit binary groups."""
    return " ".join(format(ord(ch), "08b") for ch in text)
 
 
