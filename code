def display_menu():
    print("\n  [1] Decode binary transmission вҶ’ text")
    print("  [2] Encode text вҶ’ binary transmission")
    print("  [3] Run demo transmissions")
    print("  [0] Terminate session")
    print()
 
 
def run_demo():
    demos = [
        ("01001000 01100101 01101100 01101100 01101111", "HELLO"),
        ("01001101 01001001 01010011 01010011 01001001 01001111 01001110 00100000 01000001 01000011 01000011 01000101 01010000 01010100 01000101 01000100", "MISSION ACCEPTED"),
        ("01000001 01000010 01001111 01010010 01010100", "ABORT"),
    ]
 
    print("\n  [DEMO TRANSMISSIONS]")
    print("  " + "-" * 50)
    for binary, label in demos:
        decoded = decode_binary(binary)
        print(f"  {label}:")
        print(f"    Binary  : {binary}")
        print(f"    Decoded : {decoded}")
        print()
 
 
